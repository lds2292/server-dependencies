datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["server_deps"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

enum UserStatus {
  ACTIVE
  DEACTIVATED

  @@schema("server_deps")
}

model User {
  id            String     @id @default(uuid())
  email         String              /// AES-256-GCM 암호화 저장
  emailHash     String     @unique  /// HMAC-SHA256 (조회/유일성 검증)
  username      String
  passwordHash  String?
  status        UserStatus @default(ACTIVE)
  deactivatedAt DateTime?
  createdAt     DateTime   @default(now())

  ownedProjects       Project[]           @relation("ProjectOwner")
  memberships         ProjectMember[]
  sessions            Session[]
  auditLogs           AuditLog[]
  invitationsSent     ProjectInvitation[] @relation("InvitationsSent")
  invitationsReceived ProjectInvitation[] @relation("InvitationsReceived")
  oauthAccounts       OAuthAccount[]

  @@index([status, deactivatedAt])
  @@schema("server_deps")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("server_deps")
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED

  @@schema("server_deps")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  ownerId     String
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner       User                @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  graphData   GraphData?
  auditLogs   AuditLog[]
  invitations ProjectInvitation[]

  @@index([status])
  @@schema("server_deps")
}

enum ProjectMemberRole {
  MASTER
  ADMIN
  WRITER
  READONLY

  @@schema("server_deps")
}

model ProjectMember {
  projectId String
  userId    String
  role      ProjectMemberRole @default(READONLY)
  joinedAt  DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@schema("server_deps")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED

  @@schema("server_deps")
}

model ProjectInvitation {
  id        String            @id @default(uuid())
  projectId String
  inviterId String
  inviteeId String
  role      ProjectMemberRole
  status    InvitationStatus  @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation("InvitationsSent",     fields: [inviterId], references: [id])
  invitee User    @relation("InvitationsReceived", fields: [inviteeId], references: [id])

  @@unique([projectId, inviteeId])
  @@schema("server_deps")
}

model GraphData {
  id        String   @id @default(uuid())
  projectId String   @unique
  data      Json
  contacts  Json?
  positions Json?
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("server_deps")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  projectId   String?
  action      String
  nodeId      String?
  email       String?
  status      String
  ipAddress   String?
  userAgent   String?
  failReason  String?
  detail      String?
  createdAt   DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([email, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@schema("server_deps")
}

model OAuthAccount {
  id          String   @id @default(uuid())
  userId      String
  provider    String
  providerSub String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSub])
  @@index([userId])
  @@schema("server_deps")
}
