DATABASE_URL="postgresql://user:password@localhost:5432/server_dependencies"
JWT_ACCESS_SECRET="change-this-access-secret-in-production"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
PORT=3001
CLIENT_ORIGIN="http://localhost:5173"
# 32바이트 hex 문자열 (64자) - 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-64-hex-characters"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GITHUB_CLIENT_ID="replace-with-github-client-id"
GITHUB_CLIENT_SECRET="replace-with-github-client-secret"
